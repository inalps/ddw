{
  "schemaVersion": 1,
  "workflowDir": "workflows",
  "specPath": null,
  "autoUpdateSpec": false,
  "testFilePattern": "*.test.ts",
  "userName": null,
  "paths": {
    "tasks": "tasks",
    "decisions": "decisions",
    "prds": "prds",
    "logs": "logs",
    "audits": "audits"
  },
  "commands": {
    "install": null,
    "dev": null,
    "typecheck": null,
    "test": null,
    "lint": null,
    "migrate": null
  },
  "worktree": {
    "taskDir": ".worktrees/{TASK_NAME}",
    "syncFiles": [".env", ".env.local"],
    "maxConcurrent": 3
  },
  "smoke": {
    "command": null,
    "timeoutMinutes": 5,
    "browser": {
      "mode": "playwright-or-note",
      "checks": []
    }
  },
  "auto": {
    "level": "self-driving",
    "maxConcurrent": null,
    "subagentTimeoutMinutes": 20,
    "consecutiveErrorLimit": 3,
    "confirm_on": ["destructive", "architecture", "external-side-effects"],
    "serialize_on": ["touches_db"]
  },
  "merge": {
    "mode": "local",
    "baseBranch": "main",
    "deleteBranchOnMerge": false
  }
}
