#!/usr/bin/env bash
# ddw-stage — merge a task branch into the integration worktree
# Usage: ddw-stage <TASK-id> [--root <consumer-path>]
#
# Chmod: chmod +x scripts/ddw-stage

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "Usage: ddw-stage <TASK-id> [--root <consumer-path>]"
  echo ""
  echo "  <TASK-id>     Task ID to stage (e.g. TASK-20260507-foo)"
  echo "  --root <path> Consumer repo root (default: cwd)"
  exit 1
}

# --- Parse arguments ---
TASK_ID=""
ROOT=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --root)
      shift
      ROOT="${1:-}"
      [[ -z "$ROOT" ]] && { echo "Error: --root requires a path argument" >&2; usage; }
      shift
      ;;
    --help|-h)
      usage
      ;;
    -*)
      echo "Unknown flag: $1" >&2
      usage
      ;;
    *)
      if [[ -z "$TASK_ID" ]]; then
        TASK_ID="$1"
      else
        echo "Unexpected argument: $1" >&2
        usage
      fi
      shift
      ;;
  esac
done

[[ -z "$TASK_ID" ]] && { echo "Error: TASK-id is required" >&2; usage; }

# --- Resolve root ---
if [[ -z "$ROOT" ]]; then
  ROOT="$(pwd)"
fi
ROOT="$(cd "$ROOT" && pwd)"

# Check ddw.json
if [[ ! -f "${ROOT}/ddw.json" ]]; then
  echo "Error: ddw.json not found at ${ROOT}/ddw.json. Run /ddw:init first." >&2
  exit 1
fi

node_helper="${SCRIPT_DIR}/_ddw_read_config.mjs"

read_config() {
  local key="$1"
  local default_val="${2:-}"
  local val
  val=$(node "$node_helper" "$key" "$ROOT" 2>/dev/null) || val="$default_val"
  echo "$val"
}

INTEGRATION_DIR_REL=$(read_config "worktree.integrationDir" ".worktrees/integration")
if [[ "$INTEGRATION_DIR_REL" != /* ]]; then
  INTEGRATION_DIR="${ROOT}/${INTEGRATION_DIR_REL}"
else
  INTEGRATION_DIR="$INTEGRATION_DIR_REL"
fi

DDW_DIR="${ROOT}/.ddw"
INTEGRATION_JSON="${DDW_DIR}/integration.json"

# --- Step 2: Read or create integration.json ---
mkdir -p "$DDW_DIR"
if [[ ! -f "$INTEGRATION_JSON" ]]; then
  echo '{"testing": null}' > "$INTEGRATION_JSON"
fi

# Read current testing value
CURRENTLY_TESTING=$(node -e "
  const fs = require('fs');
  try {
    const j = JSON.parse(fs.readFileSync(process.argv[1], 'utf8'));
    process.stdout.write(j.testing === null ? 'null' : String(j.testing));
  } catch(e) {
    process.stdout.write('null');
  }
" "$INTEGRATION_JSON")

# --- Step 3: Hard gate ---
if [[ "$CURRENTLY_TESTING" != "null" && "$CURRENTLY_TESTING" != "" ]]; then
  echo "Error: ${CURRENTLY_TESTING} already testing. Run /ddw:close on it or ddw-unstage first." >&2
  exit 1
fi

# --- Step 4: Refuse if integration worktree has uncommitted changes ---
if [[ ! -d "$INTEGRATION_DIR" ]]; then
  echo "Error: Integration worktree not found at ${INTEGRATION_DIR}. Set it up first." >&2
  exit 1
fi

DIRTY=$(git -C "$INTEGRATION_DIR" status --porcelain 2>/dev/null || true)
if [[ -n "$DIRTY" ]]; then
  echo "Error: Integration worktree has uncommitted changes. Refusing to merge over WIP." >&2
  exit 1
fi

# --- Step 5: Verify branch task/<TASK-id> exists ---
BRANCH="task/${TASK_ID}"
if ! git -C "$ROOT" rev-parse --verify "$BRANCH" &>/dev/null; then
  echo "Error: Branch ${BRANCH} does not exist." >&2
  exit 1
fi

# --- Step 6: Merge ---
echo "Merging ${BRANCH} into integration worktree..."
if ! git -C "$INTEGRATION_DIR" merge "$BRANCH" --no-edit 2>&1; then
  # --- Step 7: Conflict — abort ---
  git -C "$INTEGRATION_DIR" merge --abort 2>/dev/null || true
  echo "Error: Merge conflict staging ${TASK_ID}. Resolve in source branch and re-stage." >&2
  exit 1
fi

# --- Step 8: Migration detection (optional) ---
MIGRATION_GLOB=$(read_config "worktree.migrationGlob" "")
MIGRATE_CMD=$(read_config "commands.migrate" "")

if [[ -n "$MIGRATION_GLOB" && -n "$MIGRATE_CMD" ]]; then
  CHANGED_FILES=$(git -C "$INTEGRATION_DIR" diff HEAD~1..HEAD --name-only 2>/dev/null || true)
  MIGRATION_MATCHES=$(echo "$CHANGED_FILES" | grep -E "${MIGRATION_GLOB}" || true)
  if [[ -n "$MIGRATION_MATCHES" ]]; then
    echo "Running migrations: ${MIGRATE_CMD}"
    (cd "$INTEGRATION_DIR" && bash -c "$MIGRATE_CMD")
    echo "Migrations applied"
  fi
else
  : # Omit silently when not configured
fi

# --- Step 9: Update integration.json ---
node -e "
  const fs = require('fs');
  fs.writeFileSync(process.argv[1], JSON.stringify({testing: process.argv[2]}, null, 2) + '\n');
" "$INTEGRATION_JSON" "$TASK_ID"

# --- Step 10: Print success ---
echo "${TASK_ID} staged. Ready for manual test in ${INTEGRATION_DIR}."
